{
  "scripts": {
    "start": "tsx server.ts",
    "migrate:up": "node --env-file-if-exists=.env node_modules/node-pg-migrate/bin/node-pg-migrate.js --no-lock --no-reject-unauthorized up",
    "migrate:down": "node --env-file-if-exists=.env node_modules/node-pg-migrate/bin/node-pg-migrate.js --no-lock --no-reject-unauthorized down",
    "migrate:create": "node node_modules/node-pg-migrate/bin/node-pg-migrate.js create -j js"
  },
  "dependencies": {
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.13.1",
    "playwright": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.11.10"
  }
}
