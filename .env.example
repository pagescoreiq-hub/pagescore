# PageScoreIQ — environment variables
# Copy to ".env" for local use, or paste these into Railway → Variables.
# NEVER commit a real .env (it's already in .gitignore).

# ── Cloudflare R2 (report storage) ───────────────────────────────────────────
# From the Cloudflare dashboard → R2. See setup steps in HOW-TO-RUN.md.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=pagescore-reports

# Optional: if the bucket has public access (r2.dev domain or custom domain),
# set this for permanent public links. Leave blank to use 7-day presigned links.
# R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# ── Supabase Postgres (database) ─────────────────────────────────────────────
# From the Supabase dashboard → Connect.
# DATABASE_URL: app runtime — use the "Transaction pooler" URI (port 6543).
# Replace [YOUR-PASSWORD] with your database password. Append ?sslmode=no-verify
# (Supabase's pooler chain fails strict verification under newer pg; no-verify
# still encrypts the connection).
DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=no-verify

# Migrations run with `npm run migrate:up` against DATABASE_URL (--no-lock makes
# this safe over the transaction pooler). If migrations ever hang, point
# DATABASE_URL at the "Session pooler"/"Direct connection" URI (port 5432) and
# rerun, then switch back to 6543 for the app.

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# JWT_ACCESS_SECRET signs short-lived access tokens — set a long random string.
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
# Optional tuning (defaults shown):
# JWT_ACCESS_TTL_MIN=15      # access-token lifetime, minutes
# REFRESH_TTL_DAYS=30        # refresh-token lifetime, days

# ── Optional audit API keys ──────────────────────────────────────────────────
# SAFE_BROWSING_API_KEY=your_google_safe_browsing_key
# PSI_API_KEY=your_pagespeed_insights_key
